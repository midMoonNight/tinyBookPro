page {
  min-height: 100%;
  color: #20242a;
  background: #f6f7f9;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

view,
text,
input,
button,
picker {
  box-sizing: border-box;
}

button {
  margin: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.section {
  margin-bottom: 24rpx;
}

.panel {
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e8eaee;
  border-radius: 8rpx;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #161a20;
}

.muted {
  color: #7a818c;
}

.amount-income {
  color: #1f7a5b;
}

.amount-expense {
  color: #c4493a;
}

.primary-button {
  height: 84rpx;
  line-height: 84rpx;
  color: #ffffff;
  background: #1f7a5b;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.secondary-button {
  height: 76rpx;
  line-height: 76rpx;
  color: #1f7a5b;
  background: #edf7f3;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.danger-button {
  color: #c4493a;
  background: #fff1ef;
}

.input {
  width: 100%;
  min-height: 78rpx;
  padding: 0 22rpx;
  background: #f6f7f9;
  border: 1rpx solid #e3e6ea;
  border-radius: 8rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  color: #626a75;
  background: #f1f3f5;
  border-radius: 6rpx;
  font-size: 24rpx;
}
