page {
  min-height: 100%;
  color: #1d1d1f;
  background: #f2f2f7;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

view,
text,
input,
button,
picker {
  box-sizing: border-box;
}

button {
  margin: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.section {
  margin-bottom: 24rpx;
}

.panel {
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(60, 60, 67, 0.08);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.035);
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.muted {
  color: #8e8e93;
}

.amount-income {
  color: #34c759;
}

.amount-expense {
  color: #ff3b30;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  max-width: 100%;
  height: 72rpx;
  margin-right: auto;
  margin-left: auto;
  padding: 0 24rpx;
  line-height: normal;
  color: #ffffff;
  background: #007aff;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  max-width: 100%;
  height: 68rpx;
  margin-right: auto;
  margin-left: auto;
  padding: 0 24rpx;
  line-height: normal;
  color: #007aff;
  background: #eef6ff;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.primary-button::after,
.secondary-button::after {
  border: 0;
}

.danger-button {
  color: #ff3b30;
  background: #fff2f1;
}

.input {
  width: 100%;
  min-height: 78rpx;
  padding: 0 22rpx;
  background: #f2f2f7;
  border: 1rpx solid transparent;
  border-radius: 14rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  color: #636366;
  background: #f2f2f7;
  border-radius: 10rpx;
  font-size: 24rpx;
}
