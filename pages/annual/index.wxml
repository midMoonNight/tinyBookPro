<view class="page">
  <view class="panel year-head"><text class="section-title">年度统计</text><picker range="{{years}}" value="{{yearIndex}}" bindchange="onYearChange"><view class="year-picker">{{year}}年</view></picker></view>
  <view wx:if="{{annual}}" class="panel summary"><view class="summary-grid"><view><text>收入</text><text class="income">¥{{annual.incomeText}}</text></view><view><text>支出</text><text class="expense">¥{{annual.expenseText}}</text></view><view><text>结余</text><text>¥{{annual.balanceText}}</text></view><view><text>记账笔数</text><text>{{annual.recordCount}} 笔</text></view></view><view class="average-grid"><view>月均支出 <text>¥{{annual.monthAverageText}}</text></view><view>日均支出 <text>¥{{annual.dayAverageText}}</text></view></view><view wx:if="{{annual.maxMonth}}" class="highlight">支出最高月份：{{annual.maxMonth.label}}，¥{{annual.maxMonth.expenseText}}</view><view wx:if="{{annual.maxCategory}}" class="highlight">支出最高分类：{{annual.maxCategory.category}}，¥{{annual.maxCategory.amountText}}</view></view>
  <view wx:if="{{annual}}" class="section panel"><view class="section-title">月度趋势</view><view class="month-grid"><view wx:for="{{annual.months}}" wx:key="month" class="month-item" data-month="{{item.month}}" bindtap="goMonth"><text>{{item.label}}</text><text class="expense">支 ¥{{item.expenseText}}</text><text class="income">收 ¥{{item.incomeText}}</text></view></view></view>
  <view wx:if="{{annual}}" class="section panel"><view class="section-title">支出分类排名</view><view wx:if="{{annual.categories.length === 0}}" class="empty">暂无支出数据</view><view wx:for="{{annual.categories}}" wx:key="categoryId" class="category-item" data-category-id="{{item.categoryId}}" bindtap="goCategory"><view wx:if="{{item.iconPath}}" class="category-icon" style="background: {{item.background}};"><image src="{{item.iconPath}}" mode="aspectFit" /></view><view class="category-main"><view>{{item.category}}</view><view class="category-track"><view class="category-fill" style="width: {{item.percent}}%; background: {{item.foreground}};"></view></view></view><view class="category-amount">¥{{item.amountText}}<text>{{item.percent}}%</text></view></view></view>
</view>
