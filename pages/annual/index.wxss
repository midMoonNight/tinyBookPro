.year-head { display: flex; align-items: center; justify-content: space-between; }.year-head .section-title { margin: 0; }.year-picker { min-width: 150rpx; padding: 12rpx 18rpx; color: #007aff; text-align: center; background: #eef6ff; border-radius: 12rpx; }.summary { margin-top: 20rpx; }.summary-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 18rpx; }.summary-grid view { display: flex; flex-direction: column; gap: 8rpx; color: #636366; font-size: 23rpx; }.summary-grid view text:last-child { color: #1d1d1f; font-size: 30rpx; font-weight: 600; }.income { color: #34c759 !important; }.expense { color: #ff3b30 !important; }.average-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 12rpx; margin-top: 22rpx; }.average-grid view { padding: 14rpx; color: #636366; background: #f7f7fa; border-radius: 12rpx; font-size: 23rpx; }.average-grid text { display: block; margin-top: 6rpx; color: #1d1d1f; font-weight: 600; }.highlight { margin-top: 14rpx; color: #636366; font-size: 23rpx; }.month-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10rpx; }.month-item { display: flex; flex-direction: column; gap: 6rpx; padding: 14rpx 10rpx; background: #f7f7fa; border-radius: 10rpx; font-size: 21rpx; }.month-item text:first-child { color: #1d1d1f; font-weight: 600; }.category-item { display: flex; align-items: center; min-height: 84rpx; padding: 14rpx 0; border-bottom: 1rpx solid #e5e5ea; }.category-item:last-child { border-bottom: 0; }.category-icon { display: flex; align-items: center; justify-content: center; flex: 0 0 58rpx; width: 58rpx; height: 58rpx; margin-right: 14rpx; border-radius: 50%; }.category-icon image { width: 36rpx; height: 36rpx; }.category-main { flex: 1; min-width: 0; }.category-track { height: 8rpx; margin-top: 10rpx; overflow: hidden; background: #e5e5ea; border-radius: 999rpx; }.category-fill { height: 100%; border-radius: 999rpx; }.category-amount { display: flex; flex-direction: column; align-items: flex-end; gap: 5rpx; margin-left: 14rpx; font-weight: 600; }.category-amount text { color: #8e8e93; font-size: 21rpx; font-weight: 400; }
