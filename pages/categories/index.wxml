<view class="page categories-page">
  <view class="type-tabs">
    <view class="type-tab {{activeType === 'expense' ? 'active' : ''}}" data-type="expense" bindtap="onTypeTap">支出分类</view>
    <view class="type-tab {{activeType === 'income' ? 'active' : ''}}" data-type="income" bindtap="onTypeTap">收入分类</view>
  </view>

  <view class="panel category-list">
    <view wx:for="{{visibleCategories}}" wx:key="_id" class="category-item {{item.isEnabled === false ? 'disabled' : ''}}">
      <view class="category-icon" style="background: {{item.background}};"><image src="{{item.iconPath}}" mode="aspectFit" /></view>
      <view class="category-main"><view class="category-name">{{item.name}}</view><view class="category-scope">{{item.scope === 'system' ? '系统分类' : (item.isEnabled === false ? '已停用' : '自定义分类')}}</view></view>
      <view wx:if="{{item.scope === 'user'}}" class="category-actions">
        <view class="icon-action" data-id="{{item._id}}" data-direction="-1" bindtap="moveCategory">↑</view>
        <view class="icon-action" data-id="{{item._id}}" data-direction="1" bindtap="moveCategory">↓</view>
        <view class="text-action" data-id="{{item._id}}" bindtap="openEdit">编辑</view>
        <view class="text-action {{item.isEnabled === false ? 'enable' : 'danger'}}" data-id="{{item._id}}" bindtap="toggleCategory">{{item.isEnabled === false ? '启用' : '停用'}}</view>
      </view>
    </view>
  </view>

  <button class="primary-button add-category" bindtap="openCreate">新增分类</button>

  <view wx:if="{{editorVisible}}" class="editor-mask" bindtap="closeEditor">
    <view class="editor-sheet" catchtap="stopPropagation">
      <view class="editor-head"><view class="editor-title">{{editor._id ? '编辑分类' : '新增分类'}}</view><view class="editor-close" bindtap="closeEditor">×</view></view>
      <view class="field"><text class="field-label">名称</text><input class="input {{nameLength > 10 || nameInvalid ? 'input-error' : ''}}" maxlength="-1" placeholder="输入分类名称" value="{{editor.name}}" bindinput="onNameInput" /><view class="field-count {{nameLength > 10 ? 'over' : ''}}">{{nameLength}}/10</view><view class="field-hint {{nameInvalid ? 'error' : ''}}">仅支持中文、英文、数字和空格</view></view>
      <view class="field-label section-label">图标</view>
      <scroll-view scroll-y class="icon-grid-wrap"><view class="icon-grid"><view wx:for="{{icons}}" wx:key="key" class="icon-choice {{editor.iconKey === item.key ? 'selected' : ''}}" data-key="{{item.key}}" bindtap="selectIcon"><image src="{{item.path}}" mode="aspectFit" /><text>{{item.name}}</text></view></view></scroll-view>
      <view class="field-label section-label">颜色</view>
      <view class="color-grid"><view wx:for="{{colors}}" wx:key="key" class="color-choice {{editor.colorKey === item.key ? 'selected' : ''}}" style="background: {{item.background}}; border-color: {{item.foreground}};" data-key="{{item.key}}" bindtap="selectColor"><view class="color-dot" style="background: {{item.foreground}};"></view></view></view>
      <button class="primary-button editor-save" loading="{{saving}}" bindtap="saveEditor">保存分类</button>
    </view>
  </view>
</view>
