.note { color: #636366; font-size: 24rpx; }.budget-list { margin-top: 20rpx; padding-top: 0; padding-bottom: 0; }.budget-item { padding: 22rpx 0; border-bottom: 1rpx solid #e5e5ea; }.budget-item:last-child { border-bottom: 0; }.budget-head,.budget-detail,.budget-actions { display: flex; align-items: center; justify-content: space-between; }.budget-head { font-size: 24rpx; }.budget-title { display: flex; align-items: center; gap: 10rpx; min-width: 0; }.budget-name { overflow: hidden; font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }.disabled-tag { flex: none; padding: 3rpx 8rpx; color: #8e8e93; background: #f2f2f7; border-radius: 7rpx; font-size: 19rpx; }.budget-track { height: 12rpx; margin: 16rpx 0 10rpx; overflow: hidden; background: #e5e5ea; border-radius: 999rpx; }.budget-fill { height: 100%; background: #007aff; border-radius: 999rpx; }.budget-fill.warning { background: #ff9f0a; }.budget-fill.over { background: #ff3b30; }.budget-detail { color: #8e8e93; font-size: 22rpx; }.budget-actions { justify-content: flex-end; gap: 20rpx; margin-top: 12rpx; color: #007aff; font-size: 23rpx; }.danger { color: #ff3b30; }.page > .primary-button { margin-top: 24rpx; }.mask { position: fixed; z-index: 20; inset: 0; display: flex; align-items: flex-end; background: rgba(0,0,0,.35); }.sheet { width: 100%; padding: 28rpx 28rpx calc(30rpx + env(safe-area-inset-bottom)); background: #fff; border-radius: 24rpx 24rpx 0 0; }.sheet-head { display: flex; align-items: center; justify-content: space-between; }.sheet-title { font-size: 34rpx; font-weight: 600; }.close { width: 52rpx; height: 52rpx; color: #8e8e93; text-align: center; line-height: 48rpx; background: #f2f2f7; border-radius: 50%; font-size: 40rpx; }.field { margin-top: 18rpx; }.label { display: block; margin-bottom: 10rpx; color: #636366; font-size: 24rpx; }.picker-value { display: flex; align-items: center; }.save { margin-top: 26rpx; }
