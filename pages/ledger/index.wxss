.hero {
  background: #ffffff;
}

.hero-head,
.budget-line,
.budget-detail,
.stat-head,
.compact-record,
.category-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-title {
  margin-bottom: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 28rpx;
}

.summary-item {
  min-height: 132rpx;
  padding: 22rpx;
  background: #f7f7fa;
  border: 1rpx solid rgba(60, 60, 67, 0.06);
  border-radius: 14rpx;
}

.summary-label {
  display: block;
  margin-bottom: 12rpx;
  color: #8e8e93;
  font-size: 24rpx;
}

.summary-value {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.budget-box,
.budget-empty {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 14rpx;
}

.budget-box {
  background: #f2f8f4;
}

.budget-warning {
  background: #fff8e6;
}

.budget-over {
  background: #fff1ef;
}

.progress-track,
.category-track {
  overflow: hidden;
  height: 12rpx;
  background: #e5e5ea;
  border-radius: 999rpx;
}

.progress-track {
  margin: 18rpx 0;
}

.progress-fill,
.category-fill {
  height: 100%;
  background: #007aff;
  border-radius: 999rpx;
}

.budget-warning .progress-fill {
  background: #ff9f0a;
}

.budget-over .progress-fill {
  background: #ff3b30;
}

.budget-empty {
  color: #007aff;
  background: #eef6ff;
}

.type-switch {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 4rpx;
  padding: 4rpx;
  margin-bottom: 20rpx;
  background: #f2f2f7;
  border-radius: 14rpx;
}

.type-option {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  color: #636366;
  background: transparent;
  border-radius: 11rpx;
}

.type-option.active {
  color: #1d1d1f;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  font-weight: 600;
}

.field {
  margin-top: 18rpx;
}

.field-row {
  display: flex;
  gap: 18rpx;
}

.field.half {
  flex: 1;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #636366;
  font-size: 24rpx;
}

.picker-value {
  display: flex;
  align-items: center;
}

.submit {
  margin-top: 24rpx;
}

.empty {
  padding: 32rpx 0;
  color: #8e8e93;
  text-align: center;
}

.empty.small {
  padding: 20rpx 0 0;
  font-size: 24rpx;
}

.record-item {
  padding: 22rpx 0;
  border-top: 1rpx solid #e5e5ea;
}

.record-item:first-child {
  border-top: 0;
}

.record-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-category {
  margin-left: 14rpx;
  font-weight: 700;
}

.record-remark,
.record-time {
  overflow: hidden;
  margin-top: 10rpx;
  color: #8e8e93;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  margin-top: 6rpx;
  text-align: right;
}

.record-side {
  flex: 0 0 168rpx;
  min-width: 0;
}

.record-amount {
  font-size: 30rpx;
  font-weight: 600;
  text-align: right;
  white-space: nowrap;
}

.delete-button {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  width: auto;
  height: 44rpx;
  margin-top: 4rpx;
  color: #ff3b30;
  background: transparent;
  font-size: 24rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 8rpx;
  color: #636366;
  font-size: 24rpx;
}

.date-pill {
  min-width: 164rpx;
  padding: 12rpx 16rpx;
  color: #007aff;
  text-align: center;
  background: #eef6ff;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.compact-record {
  padding: 16rpx 0;
  border-top: 1rpx solid #e5e5ea;
}

.chart-title {
  margin-top: 28rpx;
  margin-bottom: 14rpx;
  color: #3a3a3c;
  font-weight: 600;
}

.trend-scroll {
  width: 100%;
}

.trend-chart {
  display: flex;
  align-items: flex-end;
  min-width: 100%;
  height: 190rpx;
  padding-top: 16rpx;
  border-bottom: 1rpx solid #d1d1d6;
}

.trend-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  width: 34rpx;
  height: 100%;
  margin-right: 8rpx;
}

.trend-bar {
  width: 18rpx;
  min-height: 0;
  background: #5ac8fa;
  border-radius: 6rpx 6rpx 0 0;
}

.trend-day {
  margin-top: 8rpx;
  color: #8e8e93;
  font-size: 20rpx;
}

.category-row {
  margin-top: 18rpx;
}

.category-info {
  margin-bottom: 10rpx;
  font-size: 24rpx;
}
