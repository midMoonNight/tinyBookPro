<view class="page profile-page">
  <view class="section panel user-panel">
    <view class="profile-row">
      <button wx:if="{{isLoggedIn}}" class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{profileAvatar}}" class="avatar" src="{{profileAvatar}}" mode="aspectFill" />
        <view wx:else class="avatar placeholder">微信</view>
      </button>
      <view wx:else class="avatar placeholder">未登</view>

      <view class="profile-main">
        <view class="status-line">
          <input
            wx:if="{{isLoggedIn}}"
            class="status-text profile-name-input {{nicknameLength > 20 ? 'input-error' : ''}}"
            type="nickname"
            maxlength="-1"
            value="{{nicknameDraft}}"
            bindinput="onNicknameInput"
            bindblur="onNicknameBlur"
            bindnicknamereview="onNicknameReview"
          />
          <view wx:if="{{isLoggedIn}}" class="nickname-count {{nicknameLength > 20 ? 'over' : ''}}">{{nicknameLength}}/20</view>
          <view wx:else class="status-text">{{statusText}}</view>
        </view>
        <view class="muted" wx:if="{{!isLoggedIn}}">当前数据仅保存在本机，登录后可同步保存。</view>
      </view>
    </view>

    <button wx:if="{{!isLoggedIn}}" class="primary-button action-button" loading="{{syncing}}" bindtap="onLogin">微信一键登录</button>
  </view>

  <view class="section panel">
    <view class="section-title">本月预算</view>
    <view class="month-line">
      <text>预算月份</text>
      <text>{{currentMonth}}</text>
    </view>
    <view class="budget-current" wx:if="{{currentBudget}}">
      当前预算：¥{{currentBudget.amount}}
    </view>
    <input class="input budget-input" type="digit" placeholder="输入本月总预算" value="{{budgetAmount}}" bindinput="onBudgetInput" />
    <button class="primary-button action-button" bindtap="onSaveBudget">保存预算</button>
  </view>

  <view class="notice">小程序只处理你主动输入的记账数据，不读取微信支付账单。</view>

  <view class="section panel settings-panel">
    <view class="setting-row" bindtap="goTemplates"><view><view class="setting-title">快捷模板</view><view class="setting-desc">保存常用账单，快速预填记账表单</view></view><text class="setting-arrow">›</text></view>
    <view class="setting-row" bindtap="goRecurring"><view><view class="setting-title">周期账单</view><view class="setting-desc">管理每周、每月或每年的重复账单</view></view><text class="setting-arrow">›</text></view>
    <view class="setting-row" bindtap="goCategoryBudgets"><view><view class="setting-title">分类预算</view><view class="setting-desc">设置本月各支出分类的预算</view></view><text class="setting-arrow">›</text></view>
    <view class="setting-row" bindtap="goCategories"><view><view class="setting-title">分类管理</view><view class="setting-desc">自定义收支分类、图标和颜色</view></view><text class="setting-arrow">›</text></view>
    <view class="setting-row" bindtap="goExport"><view><view class="setting-title">数据导出</view><view class="setting-desc">按月导出 CSV 文件</view></view><text class="setting-arrow">›</text></view>
  </view>

  <view wx:if="{{isLoggedIn}}" class="section panel">
    <button class="secondary-button danger-button" bindtap="onLogout">退出登录</button>
  </view>
</view>
