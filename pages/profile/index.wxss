.user-panel {
  padding-top: 28rpx;
}

.profile-row,
.month-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profile-row {
  align-items: flex-start;
  justify-content: flex-start;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  margin-right: 24rpx;
  border-radius: 50%;
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8e8e93;
  background: #f2f2f7;
  font-size: 24rpx;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.status-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-text {
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.profile-main .muted {
  white-space: nowrap;
  font-size: 24rpx;
}

.action-button {
  margin-top: 28rpx;
}

.month-line {
  color: #636366;
}

.budget-current {
  margin-top: 18rpx;
  color: #007aff;
  font-weight: 600;
}

.budget-input {
  margin-top: 18rpx;
}

.notice {
  margin: 0 0 24rpx;
  padding: 0 6rpx;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
}
