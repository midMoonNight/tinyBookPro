.user-panel {
  padding-top: 28rpx;
}

.profile-row,
.month-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profile-row {
  align-items: flex-start;
  justify-content: flex-start;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  margin-right: 24rpx;
  border-radius: 50%;
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8e8e93;
  background: #f2f2f7;
  font-size: 24rpx;
}

.avatar-button {
  width: 112rpx;
  height: 112rpx;
  margin: 0 24rpx 0 0;
  padding: 0;
  background: transparent;
  border-radius: 50%;
  line-height: normal;
}

.avatar-button::after {
  border: 0;
}

.avatar-button .avatar {
  margin-right: 0;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.status-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-text {
  margin-bottom: 10rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.profile-name-input {
  flex: 1;
  min-width: 0;
  width: 100%;
  height: 54rpx;
  padding: 0;
  line-height: 54rpx;
}

.nickname-count {
  flex: 0 0 auto;
  margin: 8rpx 0 0 12rpx;
  color: #8e8e93;
  font-size: 20rpx;
}

.nickname-count.over {
  color: #ff3b30;
}

.profile-main .muted {
  white-space: nowrap;
  font-size: 24rpx;
}

.action-button {
  margin-top: 28rpx;
}

.month-line {
  color: #636366;
}

.budget-current {
  overflow: hidden;
  margin-top: 18rpx;
  color: #007aff;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.budget-input {
  margin-top: 18rpx;
}

.notice {
  margin: 0 0 24rpx;
  padding: 0 6rpx;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
}

.settings-panel { padding-top: 0; padding-bottom: 0; }
.setting-row { display: flex; align-items: center; justify-content: space-between; min-height: 116rpx; border-bottom: 1rpx solid #e5e5ea; }
.setting-row:last-child { border-bottom: 0; }
.setting-title { font-weight: 600; }
.setting-desc { margin-top: 7rpx; color: #8e8e93; font-size: 23rpx; }
.setting-arrow { color: #c7c7cc; font-size: 48rpx; font-weight: 300; }
