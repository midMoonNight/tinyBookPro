.records-page { padding-bottom: 80rpx; }
.filters-panel { margin-bottom: 20rpx; }
.range-switch { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4rpx; padding: 4rpx; background: #f2f2f7; border-radius: 14rpx; }
.range-option { height: 62rpx; line-height: 62rpx; text-align: center; color: #636366; border-radius: 11rpx; }
.range-option.active { color: #1d1d1f; background: #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,.08); font-weight: 600; }
.date-filter-row,.type-filter-row,.search-row,.group-head,.history-record,.sheet-head { display: flex; align-items: center; }
.date-filter-row { justify-content: space-between; margin-top: 18rpx; }
.date-filter-row picker { flex: 1; min-width: 0; }
.date-separator { margin: 0 12rpx; color: #8e8e93; }
.filter-control { min-height: 64rpx; padding: 0 18rpx; border: 1rpx solid transparent; line-height: 64rpx; color: #3a3a3c; background: #f2f2f7; border-radius: 12rpx; font-size: 24rpx; }
.filter-control.input-error { border-color: #ff3b30; }
.date-filter-row .filter-control { text-align: center; }
.date-range-error { margin-top: 10rpx; color: #ff3b30; font-size: 22rpx; line-height: 1.4; }
.type-filter-row { gap: 10rpx; margin-top: 16rpx; }
.filter-chip { padding: 12rpx 18rpx; color: #636366; background: #f2f2f7; border-radius: 999rpx; font-size: 24rpx; }
.filter-chip.active { color: #fff; background: #007aff; }
.category-filter { flex: 1; min-width: 0; }
.category-control { overflow: hidden; text-align: center; text-overflow: ellipsis; white-space: nowrap; }
.search-row { gap: 14rpx; margin-top: 16rpx; }
.search-input { flex: 1; height: 68rpx; padding: 0 18rpx; background: #f2f2f7; border-radius: 12rpx; }
.reset-link { color: #007aff; font-size: 24rpx; }
.records-empty { padding: 80rpx 20rpx; color: #8e8e93; text-align: center; }
.record-group { margin-bottom: 20rpx; }
.group-head { justify-content: space-between; padding-bottom: 16rpx; border-bottom: 1rpx solid #e5e5ea; }
.group-date { font-weight: 600; }
.group-summary { display: flex; min-width: 0; gap: 18rpx; font-size: 22rpx; }
.group-summary text { overflow: hidden; max-width: 190rpx; text-overflow: ellipsis; white-space: nowrap; }
.history-record { min-height: 112rpx; border-bottom: 1rpx solid #e5e5ea; }
.history-record:last-child { border-bottom: 0; }
.category-icon { display: flex; align-items: center; justify-content: center; width: 68rpx; height: 68rpx; margin-right: 18rpx; border-radius: 50%; }
.category-icon image { width: 42rpx; height: 42rpx; }
.history-main { flex: 1; min-width: 0; }
.history-title { font-weight: 600; }
.history-remark { overflow: hidden; margin-top: 6rpx; color: #8e8e93; font-size: 23rpx; text-overflow: ellipsis; white-space: nowrap; }
.history-amount { overflow: hidden; flex: 0 1 240rpx; min-width: 120rpx; margin-left: 16rpx; font-size: 29rpx; font-weight: 600; text-align: right; text-overflow: ellipsis; white-space: nowrap; }
.load-state { padding: 20rpx; color: #8e8e93; text-align: center; font-size: 23rpx; }
.sheet-mask { position: fixed; z-index: 20; top: 0; right: 0; bottom: 0; left: 0; display: flex; align-items: flex-end; background: rgba(0,0,0,.35); }
.edit-sheet { width: 100%; max-height: 88vh; padding: 28rpx 28rpx calc(32rpx + env(safe-area-inset-bottom)); overflow-y: auto; background: #fff; border-radius: 24rpx 24rpx 0 0; }
.sheet-head { justify-content: space-between; margin-bottom: 22rpx; }
.sheet-title { font-size: 34rpx; font-weight: 600; }
.sheet-close { width: 52rpx; height: 52rpx; color: #8e8e93; text-align: center; line-height: 48rpx; background: #f2f2f7; border-radius: 50%; font-size: 40rpx; }
.field { margin-top: 18rpx; }
.field-row { display: flex; gap: 18rpx; }
.field.half { flex: 1; min-width: 0; }
.field-label { display: block; margin-bottom: 10rpx; color: #636366; font-size: 24rpx; }
.picker-value { display: flex; align-items: center; overflow: hidden; white-space: nowrap; }
.sheet-save { margin-top: 28rpx; }
