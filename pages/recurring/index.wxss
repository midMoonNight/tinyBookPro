.instance-item,.plan-item,.history-item { display: flex; align-items: center; justify-content: space-between; min-height: 104rpx; padding: 16rpx 0; border-bottom: 1rpx solid #e5e5ea; }.instance-item:last-child,.plan-item:last-child,.history-item:last-child { border-bottom: 0; }.instance-main,.plan-main { flex: 1; min-width: 0; }.instance-title,.plan-title { font-weight: 600; }.instance-detail,.plan-detail { margin-top: 6rpx; overflow: hidden; color: #8e8e93; font-size: 23rpx; text-overflow: ellipsis; white-space: nowrap; }.instance-actions,.plan-actions { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 10rpx 14rpx; margin-left: 14rpx; color: #007aff; font-size: 23rpx; }.muted-action,.disabled-action { color: #8e8e93; }.history-list { padding-top: 0; padding-bottom: 0; }.history-list .section-title { padding-top: 24rpx; }.history-status { flex: none; margin-left: 16rpx; color: #248a3d; font-size: 23rpx; }.history-status.skipped { color: #8e8e93; }.danger { color: #ff3b30; }.plan-list { margin-top: 20rpx; padding-top: 0; padding-bottom: 0; }.disabled { opacity: .48; }.page > .primary-button { margin-top: 24rpx; }.mask { position: fixed; z-index: 20; inset: 0; display: flex; align-items: flex-end; background: rgba(0,0,0,.35); }.sheet { width: 100%; max-height: 92vh; padding: 28rpx 28rpx calc(30rpx + env(safe-area-inset-bottom)); overflow-y: auto; background: #fff; border-radius: 24rpx 24rpx 0 0; }.sheet-head { display: flex; align-items: center; justify-content: space-between; }.sheet-title { font-size: 34rpx; font-weight: 600; }.close { width: 52rpx; height: 52rpx; color: #8e8e93; text-align: center; line-height: 48rpx; background: #f2f2f7; border-radius: 50%; font-size: 40rpx; }.field { margin-top: 18rpx; }.label { display: block; margin-bottom: 10rpx; color: #636366; font-size: 24rpx; }.picker-value { display: flex; align-items: center; }.save { margin-top: 26rpx; }
