.intro { color: #636366; font-size: 24rpx; }.template-list { padding-top: 0; padding-bottom: 0; margin-top: 20rpx; }.template-item { display: flex; align-items: center; min-height: 110rpx; border-bottom: 1rpx solid #e5e5ea; }.template-item:last-child { border-bottom: 0; }.template-item.disabled { opacity: .48; }.template-main { flex: 1; min-width: 0; }.template-name { font-weight: 600; }.template-detail { margin-top: 7rpx; overflow: hidden; color: #8e8e93; font-size: 23rpx; text-overflow: ellipsis; white-space: nowrap; }.template-actions { display: flex; gap: 12rpx; margin-left: 12rpx; color: #007aff; font-size: 22rpx; }.template-actions .danger { color: #ff3b30; }.page > .primary-button { margin-top: 24rpx; }.mask { position: fixed; z-index: 20; inset: 0; display: flex; align-items: flex-end; background: rgba(0,0,0,.35); }.sheet { width: 100%; max-height: 90vh; padding: 28rpx 28rpx calc(30rpx + env(safe-area-inset-bottom)); overflow-y: auto; background: #fff; border-radius: 24rpx 24rpx 0 0; }.sheet-head { display: flex; align-items: center; justify-content: space-between; }.sheet-title { font-size: 34rpx; font-weight: 600; }.close { width: 52rpx; height: 52rpx; color: #8e8e93; text-align: center; line-height: 48rpx; background: #f2f2f7; border-radius: 50%; font-size: 40rpx; }.field { margin-top: 18rpx; }.label { display: block; margin-bottom: 10rpx; color: #636366; font-size: 24rpx; }.picker-value { display: flex; align-items: center; }.save { margin-top: 26rpx; }
